@inject FundingCommitmentService Svc
@inject ToastService Toasts

@{
    var st = StatusInfo.For(R.Status);
    var (c1, c2) = Catalog.ClientColor(R.ClientId);
    var rv = Svc.ViewFor(R);
    var total = R.Total;
    var totalPlan = R.TotalPlan;
    var overBudget = R.OverBudget;
    var showApprove = R.Status is CommitmentStatus.Draft or CommitmentStatus.Pending
                      or CommitmentStatus.Awaiting or CommitmentStatus.Special
                      or CommitmentStatus.Finance or CommitmentStatus.Ministry;
    var showRevise = R.Status is CommitmentStatus.Approved or CommitmentStatus.Active or CommitmentStatus.Rejected;
    var hasAddl = !string.IsNullOrEmpty(R.AddlFunder) && R.AddlFunder != "— None —";
    var chipCap = rv == RowView.Detailed ? 4 : 3;
    var chipTypes = R.MccssTypes.Take(chipCap).ToList();
    var extraCount = Math.Max(0, R.MccssTypes.Count - chipCap);
    var rvClass = rv switch { RowView.Detailed => "detailed", RowView.Ultra => "ultra", _ => "compact" };
    var cycleTitle = rv == RowView.Ultra ? "Expand to compact view"
                    : rv == RowView.Compact ? "Expand to detailed view"
                    : "Collapse to ultra view";
}

<article class="commit @rvClass @(R.Selected ? "selected" : "") @(Focused ? "focused" : "")"
         data-id="@R.CommitId" data-status="@st.Key" data-view="@rvClass"
         @onclick="OnArticleClick" @onclick:stopPropagation="false">

    <div class="commit-head">
        <div class="chk @(R.Selected ? "checked" : "")" @onclick="Toggle" @onclick:stopPropagation="true"></div>

        <div class="client-cell" @onclick="@(() => OpenFull("details"))" @onclick:stopPropagation="true" title="Open full record">
            <div class="av" style="background:linear-gradient(135deg, @c1, @c2)">@Initials(R.ClientName)</div>
            <div class="meta">
                <div class="nm">@R.ClientName<span class="cid">#@R.ClientId</span></div>
                <div class="sub">DOB @R.Dob</div>
            </div>
        </div>

        <div class="fund-chips" @onclick="@(() => OpenFull("services"))" @onclick:stopPropagation="true" title="See full funding breakdown">
            @if (chipTypes.Count == 0)
            {
                <span class="fc empty">No funding type</span>
            }
            else
            {
                @foreach (var t in chipTypes)
                {
                    var amt = R.PlanAmounts.TryGetValue(t, out var v) ? v : 0;
                    var assigned = R.Services.Where(s => s.Plan == t).Sum(s => s.LineTotal);
                    var over = amt > 0 && assigned > amt;
                    <span class="fc @(over ? "over" : "")" title="@t — Plan @Money(amt) · Assigned @Money(assigned)">
                        <span class="fc-nm">@Catalog.ShortFundingLabel(t)</span>
                        <span class="fc-amt">@MoneyShort(amt)</span>
                    </span>
                }
                @if (extraCount > 0)
                {
                    <span class="more" title="@string.Join("\n", R.MccssTypes.Skip(chipCap))">+@extraCount</span>
                }
            }
        </div>

        <div class="id-cell" @onclick="@(() => OpenFull("history"))" @onclick:stopPropagation="true" title="Open record history">
            @R.CommitId–@R.ClientId–@R.Year
        </div>

        <div>
            <button class="status-pill @st.CssClass" @onclick="OpenStatusMenu" @onclick:stopPropagation="true">
                @st.Label
                <svg class="caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6" /></svg>
            </button>
        </div>

        <div class="activity">
            @if (R.Attachments > 0)
            {
                <span class="a-item" @onclick="@(() => OpenFull("attachments"))" @onclick:stopPropagation="true" title="Attachments">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21.4 11.05 12.25 20.2a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.49" /></svg>
                    <span class="ct">@R.Attachments</span>
                </span>
            }
            @if (R.Messages > 0)
            {
                <span class="a-item" @onclick="@(() => OpenFull("messages"))" @onclick:stopPropagation="true" title="Messages">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" /></svg>
                    <span class="ct">@R.Messages</span>
                </span>
            }
            @if (R.History > 0)
            {
                <span class="a-item" @onclick="@(() => OpenFull("history"))" @onclick:stopPropagation="true" title="History">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 3" /></svg>
                    <span class="ct">@R.History</span>
                </span>
            }
        </div>

        <div class="amt-block" @onclick="@(() => OpenFull("funding"))" @onclick:stopPropagation="true" title="Open funding allocation">
            <div class="lbl">Committed</div>
            <div class="v @(total == 0 ? "zero" : "") @(overBudget ? "over" : "")">@Money(total)</div>
        </div>

        <div class="actions-cell">
            @if (showApprove)
            {
                <button class="act-btn approve" @onclick="Approve" @onclick:stopPropagation="true" title="Approve (A)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5" /></svg>
                    Approve
                </button>
            }
            @if (showRevise)
            {
                <button class="act-btn revise" @onclick="Revise" @onclick:stopPropagation="true" title="Revise">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                    Revise
                </button>
            }
            <button class="act-btn @(rv == RowView.Ultra ? "expand-btn" : "")" @onclick="CycleView" @onclick:stopPropagation="true" title="@cycleTitle">
                @if (rv == RowView.Ultra)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6" /></svg>
                    <span class="cb-lbl">Expand</span>
                }
                else if (rv == RowView.Compact)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 9h18M3 15h18M9 3v18" /></svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 15-6-6-6 6" /></svg>
                }
            </button>
            <button class="act-btn" @onclick="@(() => OpenFull("details"))" @onclick:stopPropagation="true" title="Open full detail view">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" /></svg>
            </button>
            <button class="act-btn" @onclick="OpenOverflowMenu" @onclick:stopPropagation="true" title="More actions">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1.4" /><circle cx="12" cy="12" r="1.4" /><circle cx="12" cy="19" r="1.4" /></svg>
            </button>
        </div>
    </div>

    @if (rv != RowView.Ultra)
    {
        <!-- META GRID -->
        <div class="meta-grid">
            <div class="field-cell">
                <label class="lbl">Plan Period</label>
                <div class="date-range">
                    <input type="date" value="@R.PlanStart" @onchange="@(e => Svc.UpdateField(R.CommitId, "planStart", e.Value?.ToString() ?? ""))" @onclick:stopPropagation="true" />
                    <span>→</span>
                    <input type="date" value="@R.PlanEnd" @onchange="@(e => Svc.UpdateField(R.CommitId, "planEnd", e.Value?.ToString() ?? ""))" @onclick:stopPropagation="true" />
                </div>
            </div>
            <div class="field-cell">
                <label class="lbl">Main Funder <span class="req">*</span></label>
                <select value="@R.MainFunder" @onchange="@(e => Svc.UpdateField(R.CommitId, "mainFunder", e.Value?.ToString() ?? ""))" @onclick:stopPropagation="true">
                    @foreach (var t in Catalog.MainFunders) { <option value="@t" selected="@(t == R.MainFunder)">@t</option> }
                </select>
            </div>
            <div class="field-cell field-mccss" style="grid-column:span 3">
                <label class="lbl">
                    MCCSS Funding Type(s) <span class="req">*</span>
                    <span class="hint-pill">@R.MccssTypes.Count selected · click to toggle</span>
                </label>
                <div class="mccss-chips">
                    @foreach (var f in Catalog.MccssFunding)
                    {
                        var on = R.MccssTypes.Contains(f);
                        <button type="button" class="mc-chip @(on ? "on" : "")" @onclick="() => ToggleMccss(f)" @onclick:stopPropagation="true">
                            <span class="dot"></span>@f
                        </button>
                    }
                </div>
                @if (R.MccssTypes.Count > 0)
                {
                    <div class="plan-amount-grid">
                        @foreach (var t in R.MccssTypes)
                        {
                            var amt = R.PlanAmounts.TryGetValue(t, out var v) ? v : 0;
                            <div class="pa-cell">
                                <label class="pa-lbl">@Catalog.ShortFundingLabel(t) <span class="pa-full">@t</span></label>
                                <div class="input-wrap">
                                    <span class="currency">$</span>
                                    <input type="number" min="0" step="0.01" placeholder="0.00"
                                           value="@(amt == 0 ? "" : amt.ToString("0.##"))"
                                           @onchange="@(e => SetPlanAmount(t, e.Value?.ToString()))"
                                           @onclick:stopPropagation="true" />
                                </div>
                            </div>
                        }
                        <div class="pa-cell pa-total">
                            <label class="pa-lbl">Total Plan</label>
                            <div class="pa-total-v">@Money(totalPlan)</div>
                        </div>
                    </div>
                }
            </div>
            <div class="field-cell">
                <label class="lbl">MCCSS Plan Type</label>
                <div class="plan-type-toggle">
                    @foreach (var p in Catalog.PlanTypes)
                    {
                        var pt = p;
                        <button type="button" class="pt-btn @(p == R.PlanType ? "on" : "")"
                                @onclick="() => SetPlanType(pt)" @onclick:stopPropagation="true">@p</button>
                    }
                </div>
            </div>
            <div class="field-cell">
                <label class="lbl">SCS Team Accountable</label>
                <select value="@R.Ministry" @onchange="@(e => Svc.UpdateField(R.CommitId, "ministry", e.Value?.ToString() ?? ""))" @onclick:stopPropagation="true">
                    @foreach (var m in Catalog.Ministries) { <option value="@m" selected="@(m == R.Ministry)">@m</option> }
                </select>
            </div>

            <div class="field-cell">
                <label class="lbl">Funding Type</label>
                <select value="@R.FundingType" @onchange="@(e => Svc.UpdateField(R.CommitId, "fundingType", e.Value?.ToString() ?? ""))" @onclick:stopPropagation="true">
                    @foreach (var t in Catalog.FundingTypes) { <option value="@t" selected="@(t == R.FundingType)">@t</option> }
                </select>
            </div>
            <div class="field-cell">
                <label class="lbl">Placement</label>
                <select value="@R.Placement" @onchange="@(e => Svc.UpdateField(R.CommitId, "placement", e.Value?.ToString() ?? ""))" @onclick:stopPropagation="true">
                    @foreach (var t in Catalog.Placements) { <option value="@t" selected="@(t == R.Placement)">@t</option> }
                </select>
            </div>
            <div class="field-cell">
                <label class="lbl">Additional Funder(s)</label>
                <select value="@R.AddlFunder" @onchange="@(e => Svc.UpdateField(R.CommitId, "addlFunder", e.Value?.ToString() ?? ""))" @onclick:stopPropagation="true">
                    @foreach (var t in Catalog.AddlFunders) { <option value="@t" selected="@(t == R.AddlFunder)">@t</option> }
                </select>
            </div>
            <div class="field-cell @(string.IsNullOrEmpty(R.Outcome) ? "is-empty" : "")" style="grid-column:span 2">
                <label class="lbl">Funding Commitment Outcome</label>
                <input type="text" placeholder="Expected outcome…"
                       value="@R.Outcome"
                       @onchange="@(e => Svc.UpdateField(R.CommitId, "outcome", e.Value?.ToString() ?? ""))"
                       @onclick:stopPropagation="true" />
            </div>
            <div class="field-cell @(string.IsNullOrEmpty(R.AltSources) ? "is-empty" : "")">
                <label class="lbl">Alternative Funding Sources</label>
                <input type="text" placeholder="e.g., family, charity…"
                       value="@R.AltSources"
                       @onchange="@(e => Svc.UpdateField(R.CommitId, "altSources", e.Value?.ToString() ?? ""))"
                       @onclick:stopPropagation="true" />
            </div>
        </div>

        @if (hasAddl)
        {
            <div class="strip-additional">
                <div class="funder-marker">
                    <div class="lbl">Additional Funder</div>
                    <div class="nm">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                        @R.AddlFunder
                    </div>
                </div>
                <div class="field-cell" style="grid-column:span 2">
                    <label class="lbl">Commitment Amount</label>
                    <div class="input-wrap">
                        <span class="currency">$</span>
                        <input type="number" min="0" step="0.01" placeholder="0.00"
                               value="@(R.AddlFunderAmount == 0 ? "" : R.AddlFunderAmount.ToString("0.##"))"
                               @onchange="@(e => SetAddlAmount(e.Value?.ToString()))"
                               @onclick:stopPropagation="true" />
                    </div>
                </div>
                <div class="field-cell" style="grid-column:span 2">
                    <label class="lbl">Assign Amount to Vendor</label>
                    <div class="input-wrap">
                        <span class="currency">$</span>
                        <input type="number" min="0" step="0.01" placeholder="0.00"
                               value="@(R.AddlFunderVendor == 0 ? "" : R.AddlFunderVendor.ToString("0.##"))"
                               @onchange="@(e => SetAddlVendor(e.Value?.ToString()))"
                               @onclick:stopPropagation="true" />
                    </div>
                </div>
            </div>
        }

        <!-- SERVICES TABLE -->
        <div class="commit-services">
            <div class="svc-header">
                <div></div>
                <div>Service</div>
                <div>Vendor</div>
                <div class="col-provider">Provider Type</div>
                <div>Unit</div>
                <div class="num-h">Rate</div>
                <div class="num-h">Units</div>
                <div class="num-h">Line Total</div>
                <div style="text-align:center">Note</div>
                <div></div>
            </div>
            @for (var i = 0; i < R.Services.Count; i++)
            {
                var ix = i;
                var sv = R.Services[ix];
                var lineT = sv.LineTotal;
                var hasNote = !string.IsNullOrWhiteSpace(sv.Note);
                <div class="svc-row" @key="ix">
                    <div class="idx">@(ix + 1)</div>
                    <div>
                        <select class="svc-input @(string.IsNullOrEmpty(sv.Name) ? "unset" : "")"
                                @onchange="@(e => Svc.UpdateServiceField(R.CommitId, ix, "name", e.Value?.ToString() ?? ""))"
                                @onclick:stopPropagation="true">
                            <option value="" selected="@string.IsNullOrEmpty(sv.Name)">— Select service —</option>
                            @foreach (var n in Catalog.Services) { <option value="@n" selected="@(n == sv.Name)">@n</option> }
                        </select>
                    </div>
                    <div>
                        <select class="svc-input vendor-input"
                                @onchange="@(e => Svc.UpdateServiceField(R.CommitId, ix, "vendor", e.Value?.ToString() ?? ""))"
                                @onclick:stopPropagation="true">
                            @foreach (var n in Catalog.Vendors) { <option value="@n" selected="@(n == sv.Vendor)">@n</option> }
                        </select>
                    </div>
                    <div class="col-provider">
                        <select class="svc-input"
                                @onchange="@(e => Svc.UpdateServiceField(R.CommitId, ix, "provider", e.Value?.ToString() ?? ""))"
                                @onclick:stopPropagation="true">
                            @foreach (var n in Catalog.Providers) { <option value="@n" selected="@(n == sv.Provider)">@n</option> }
                        </select>
                    </div>
                    <div>
                        <select class="svc-input"
                                @onchange="@(e => Svc.UpdateServiceField(R.CommitId, ix, "unit", e.Value?.ToString() ?? ""))"
                                @onclick:stopPropagation="true">
                            @foreach (var n in Catalog.Units) { <option value="@n" selected="@(n == sv.Unit)">@n</option> }
                        </select>
                    </div>
                    <div>
                        <input type="number" min="0" step="0.01" class="svc-input money-input" placeholder="—"
                               value="@(sv.Rate == 0 ? "" : sv.Rate.ToString("0.##"))"
                               @onchange="@(e => SetServiceRate(ix, e.Value?.ToString()))"
                               @onclick:stopPropagation="true" />
                    </div>
                    <div>
                        <input type="number" min="0" step="1" class="svc-input money-input" placeholder="—"
                               value="@(sv.Units == 0 ? "" : sv.Units.ToString("0.##"))"
                               @onchange="@(e => SetServiceUnits(ix, e.Value?.ToString()))"
                               @onclick:stopPropagation="true" />
                    </div>
                    <div class="svc-total @(lineT == 0 ? "zero" : "")">@(lineT == 0 ? "—" : Money(lineT))</div>
                    <div>
                        <button class="note-btn @(hasNote ? "has-note" : "")"
                                @onclick="@(() => OnNoteClick(ix))" @onclick:stopPropagation="true"
                                title="@(hasNote ? "Edit note" : "Add note")">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                        </button>
                    </div>
                    <div>
                        <button class="svc-del" @onclick="@(() => DeleteService(ix))" @onclick:stopPropagation="true" title="Delete row">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" /></svg>
                        </button>
                    </div>
                </div>
            }
            <div class="svc-add" @onclick="AddService" @onclick:stopPropagation="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" /></svg>
                Add service line
            </div>
        </div>

        <!-- FOOTER -->
        <div class="commit-foot">
            <div class="left">
                <span class="crumb">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 3" /></svg>
                    <span class="audit">@R.Date · @R.Time</span>
                </span>
                <span class="crumb">by <strong>@R.Creator</strong></span>
                @if (totalPlan > 0)
                {
                    var diff = Math.Abs(totalPlan - total);
                    <span class="budget @(overBudget ? "over" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                        @(overBudget ? "Over by" : "Remaining") <strong>@Money(diff)</strong>
                        <span style="color:var(--ink-3);font-size:10.5px;margin-left:2px;">of @Money(totalPlan)</span>
                    </span>
                }
            </div>
            <div class="foot-actions">
                <button class="foot-btn ghost" @onclick="CollapseToUltra" @onclick:stopPropagation="true" title="Collapse to ultra view">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 15-6-6-6 6" /></svg>
                    Collapse
                </button>
                @if (showRevise)
                {
                    <button class="foot-btn" @onclick="Revise" @onclick:stopPropagation="true" title="Send back to draft">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                        Send back to Draft
                    </button>
                }
                @if (showApprove)
                {
                    <button class="foot-btn reject" @onclick="RejectRow" @onclick:stopPropagation="true" title="Not approve">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 6 6 18M6 6l12 12" /></svg>
                        Reject
                    </button>
                    <button class="foot-btn approve-next" @onclick="ApproveAndAdvance" @onclick:stopPropagation="true" title="Approve & move to next (A)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5" /></svg>
                        Approve &amp; next
                        <span class="kbd-inline">A</span>
                    </button>
                }
            </div>
        </div>
    }
</article>

@code {
    [Parameter, EditorRequired] public FundingCommitment R { get; set; } = default!;
    [Parameter] public bool Focused { get; set; }
    [Parameter] public EventCallback<(string commitId, double left, double top, string anchor)> OnRequestStatusMenu { get; set; }
    [Parameter] public EventCallback<(string commitId, double left, double top, string anchor)> OnRequestOverflowMenu { get; set; }
    [Parameter] public EventCallback<(string commitId, int idx, double left, double top, string anchor)> OnRequestNotePopover { get; set; }
    [Parameter] public EventCallback<(string commitId, string tab)> OnOpenFullView { get; set; }

    private void Toggle() => Svc.ToggleSelect(R.CommitId);

    private void Approve()
    {
        Svc.Approve(R.CommitId);
        Toasts.Show(ToastKind.Success, $"{R.ClientName} approved");
    }

    private async Task ApproveAndAdvance()
    {
        var nextId = Svc.ApproveAndAdvance(R.CommitId);
        Toasts.Show(ToastKind.Success, $"{R.ClientName} approved");
        if (!string.IsNullOrEmpty(nextId)) Svc.RequestScrollToCommit(nextId);
        await Task.CompletedTask;
    }

    private void Revise()
    {
        Svc.Revise(R.CommitId);
        Toasts.Show(ToastKind.Success, $"{R.ClientName} sent back to draft");
    }

    private void RejectRow()
    {
        Svc.Reject(R.CommitId);
        Toasts.Show(ToastKind.Warning, $"{R.ClientName} marked Not Approved");
    }

    private void CycleView() => Svc.CycleRowView(R.CommitId);
    private void CollapseToUltra() => Svc.CollapseRowToUltra(R.CommitId);

    private void ToggleMccss(string type)
    {
        Svc.ToggleMccss(R.CommitId, type, msg =>
        {
            Toasts.Show(ToastKind.Warning, msg);
            return false;
        });
    }

    private void SetPlanAmount(string type, string? value)
    {
        decimal.TryParse(value, out var v);
        Svc.SetPlanAmount(R.CommitId, type, v);
    }

    private void SetNumField(string key, string? value)
    {
        decimal.TryParse(value, out var v);
        Svc.UpdateFieldNumber(R.CommitId, key, v);
    }

    private void SetAddlAmount(string? value) => SetNumField("addlFunderAmount", value);
    private void SetAddlVendor(string? value) => SetNumField("addlFunderVendor", value);

    private void SetServiceNum(int idx, string key, string? value)
    {
        decimal.TryParse(value, out var v);
        Svc.UpdateServiceNumber(R.CommitId, idx, key, v);
    }

    private void SetServiceRate(int idx, string? value) => SetServiceNum(idx, "rate", value);
    private void SetServiceUnits(int idx, string? value) => SetServiceNum(idx, "units", value);

    private void SetPlanType(string pt) => Svc.UpdateField(R.CommitId, "planType", pt);

    private void AddService()
    {
        Svc.AddService(R.CommitId);
        Toasts.Show(ToastKind.Success, "Service line added");
    }

    private void DeleteService(int idx)
    {
        var ok = Svc.DeleteService(R.CommitId, idx, msg =>
        {
            Toasts.Show(ToastKind.Warning, msg);
            return false;
        });
        if (ok) Toasts.Show(ToastKind.Warning, "Service line removed");
    }

    private async Task OpenStatusMenu(MouseEventArgs e)
    {
        await OnRequestStatusMenu.InvokeAsync((R.CommitId, e.ClientX, e.ClientY, "status"));
    }

    private async Task OpenOverflowMenu(MouseEventArgs e)
    {
        await OnRequestOverflowMenu.InvokeAsync((R.CommitId, e.ClientX, e.ClientY, "overflow"));
    }

    private async Task OnNoteClick(int idx)
    {
        await OnRequestNotePopover.InvokeAsync((R.CommitId, idx, 0, 0, "note"));
    }

    private async Task OpenFull(string tab)
    {
        await OnOpenFullView.InvokeAsync((R.CommitId, tab));
    }

    private async Task OnArticleClick()
    {
        // Ultra view click expands to compact
        if (Svc.ViewFor(R) == RowView.Ultra)
        {
            Svc.ExpandRowFromUltra(R.CommitId);
        }
        await Task.CompletedTask;
    }

    private static string Money(decimal n) => "$" + n.ToString("N2");
    private static string MoneyShort(decimal n) => "$" + n.ToString("N0");

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "";
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }
}
