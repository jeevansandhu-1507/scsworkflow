@inject FundingCommitmentService Svc
@inject ToastService Toasts

<div class="bulk-overlay @(_open ? "open" : "")" @onclick="Close"></div>
<aside class="bulk-drawer @(_open ? "open" : "")" aria-hidden="@(_open ? "false" : "true")">
    @if (_open)
    {
        var sel = Svc.SelectedRows.ToList();
        var uniqueClients = sel.Select(r => r.ClientId).Distinct().Count();
        var planSum = sel.Sum(r => r.TotalPlan);
        var parts = PreviewParts();

        <header class="bd-head">
            <div>
                <div class="bd-eyebrow">Bulk Edit</div>
                <h2>@sel.Count commitment@(sel.Count == 1 ? "" : "s")</h2>
                <p class="bd-sub">@uniqueClients client@(uniqueClients == 1 ? "" : "s") · plan @MoneyShort(planSum)</p>
            </div>
            <button class="bd-close" @onclick="Close" title="Close (Esc)" aria-label="Close bulk edit drawer">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false"><path d="M18 6 6 18M6 6l12 12" /></svg>
            </button>
        </header>

        <div class="bd-hint">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9" /><path d="M12 16v-4M12 8h.01" /></svg>
            Toggle a field to opt in. Only enabled fields will be written to selected records.
        </div>

        <div class="bd-body">
            <div class="bd-field @(_changes.EnableStatus ? "enabled" : "")">
                <label class="bd-tog"><input type="checkbox" checked="@_changes.EnableStatus" @onchange="@(e => { _changes.EnableStatus = (bool?)e.Value ?? false; })" /><span>Status</span></label>
                <select disabled="@(!_changes.EnableStatus)"
                        @onchange="@(e => SetStatus(e.Value?.ToString()))">
                    @foreach (var s in StatusInfo.All)
                    {
                        var info = StatusInfo.For(s);
                        <option value="@s.ToString()" selected="@(_changes.Status == s)">@info.Label</option>
                    }
                </select>
            </div>

            <div class="bd-field @(_changes.EnablePlanPeriod ? "enabled" : "")">
                <label class="bd-tog"><input type="checkbox" checked="@_changes.EnablePlanPeriod" @onchange="@(e => { _changes.EnablePlanPeriod = (bool?)e.Value ?? false; })" /><span>Plan Period</span></label>
                <div class="bd-dates">
                    <input type="date" disabled="@(!_changes.EnablePlanPeriod)" value="@_changes.PlanStart" @onchange="@(e => { _changes.PlanStart = e.Value?.ToString() ?? ""; })" />
                    <span>→</span>
                    <input type="date" disabled="@(!_changes.EnablePlanPeriod)" value="@_changes.PlanEnd" @onchange="@(e => { _changes.PlanEnd = e.Value?.ToString() ?? ""; })" />
                </div>
            </div>

            <div class="bd-field @(_changes.EnableMccss ? "enabled" : "")">
                <label class="bd-tog"><input type="checkbox" checked="@_changes.EnableMccss" @onchange="@(e => { _changes.EnableMccss = (bool?)e.Value ?? false; })" /><span>MCCSS Funding Type(s)</span></label>
                <div class="bd-mode-row">
                    <label class="bd-radio">
                        <input type="radio" name="bdMccssMode" disabled="@(!_changes.EnableMccss)"
                               checked="@(_changes.MccssMode == BulkMccssMode.Replace)"
                               @onchange="@(_ => _changes.MccssMode = BulkMccssMode.Replace)" />
                        <span>Replace</span>
                    </label>
                    <label class="bd-radio">
                        <input type="radio" name="bdMccssMode" disabled="@(!_changes.EnableMccss)"
                               checked="@(_changes.MccssMode == BulkMccssMode.Add)"
                               @onchange="@(_ => _changes.MccssMode = BulkMccssMode.Add)" />
                        <span>Add</span>
                    </label>
                    <label class="bd-radio">
                        <input type="radio" name="bdMccssMode" disabled="@(!_changes.EnableMccss)"
                               checked="@(_changes.MccssMode == BulkMccssMode.Remove)"
                               @onchange="@(_ => _changes.MccssMode = BulkMccssMode.Remove)" />
                        <span>Remove</span>
                    </label>
                </div>
                <div class="mccss-chips">
                    @foreach (var f in Catalog.MccssFunding)
                    {
                        var ft = f;
                        var on = _changes.MccssTypes.Contains(ft);
                        <button type="button" class="mc-chip @(on ? "on" : "")" disabled="@(!_changes.EnableMccss)"
                                @onclick="() => ToggleBulkMccss(ft)">
                            <span class="dot"></span>@f
                        </button>
                    }
                </div>
            </div>

            <div class="bd-field @(_changes.EnablePlanType ? "enabled" : "")">
                <label class="bd-tog"><input type="checkbox" checked="@_changes.EnablePlanType" @onchange="@(e => { _changes.EnablePlanType = (bool?)e.Value ?? false; })" /><span>MCCSS Plan Type</span></label>
                <div class="plan-type-toggle">
                    @foreach (var p in Catalog.PlanTypes)
                    {
                        var pt = p;
                        <button type="button" class="pt-btn @(p == _changes.PlanType ? "on" : "")"
                                disabled="@(!_changes.EnablePlanType)"
                                @onclick="() => _changes.PlanType = pt">@p</button>
                    }
                </div>
            </div>

            <div class="bd-field @(_changes.EnableMinistry ? "enabled" : "")">
                <label class="bd-tog"><input type="checkbox" checked="@_changes.EnableMinistry" @onchange="@(e => { _changes.EnableMinistry = (bool?)e.Value ?? false; })" /><span>SCS Team Accountable</span></label>
                <select disabled="@(!_changes.EnableMinistry)" @onchange="@(e => { _changes.Ministry = e.Value?.ToString() ?? Catalog.Ministries[0]; })">
                    @foreach (var m in Catalog.Ministries) { <option value="@m" selected="@(m == _changes.Ministry)">@m</option> }
                </select>
            </div>

            <div class="bd-field @(_changes.EnableOutcome ? "enabled" : "")">
                <label class="bd-tog"><input type="checkbox" checked="@_changes.EnableOutcome" @onchange="@(e => { _changes.EnableOutcome = (bool?)e.Value ?? false; })" /><span>Funding Commitment Outcome</span></label>
                <input type="text" disabled="@(!_changes.EnableOutcome)" placeholder="Expected outcome…"
                       value="@_changes.Outcome" @onchange="@(e => { _changes.Outcome = e.Value?.ToString() ?? ""; })" />
            </div>
        </div>

        <footer class="bd-foot">
            <div class="bd-preview @(parts.Count > 0 ? "active" : "")">@(parts.Count == 0 ? "No changes selected" : string.Join(" · ", parts))</div>
            <div class="bd-actions">
                <button class="btn ghost" @onclick="Close">Cancel</button>
                <button class="btn primary" disabled="@(!_changes.HasAnyChange || sel.Count == 0)" @onclick="Apply">
                    Apply to <span>@sel.Count</span>
                </button>
            </div>
        </footer>
    }
</aside>

@code {
    private bool _open;
    private BulkChanges _changes = new();

    public bool IsOpen => _open;

    public void Open()
    {
        if (Svc.SelectedCount == 0)
        {
            Toasts.Show(ToastKind.Warning, "Select one or more commitments first");
            return;
        }
        _changes = new BulkChanges();
        _open = true;
        StateHasChanged();
    }

    public void Close()
    {
        _open = false;
        StateHasChanged();
    }

    private void SetStatus(string? value)
    {
        if (Enum.TryParse<CommitmentStatus>(value, out var s)) _changes.Status = s;
    }

    private void ToggleBulkMccss(string type)
    {
        if (_changes.MccssTypes.Contains(type)) _changes.MccssTypes.Remove(type);
        else _changes.MccssTypes.Add(type);
    }

    private List<string> PreviewParts()
    {
        var parts = new List<string>();
        if (_changes.EnableStatus) parts.Add($"status → {StatusInfo.For(_changes.Status).Label}");
        if (_changes.EnablePlanPeriod) parts.Add($"period → {(string.IsNullOrEmpty(_changes.PlanStart) ? "?" : _changes.PlanStart)} → {(string.IsNullOrEmpty(_changes.PlanEnd) ? "?" : _changes.PlanEnd)}");
        if (_changes.EnableMccss && _changes.MccssTypes.Count > 0)
        {
            var modeLabel = _changes.MccssMode switch
            {
                BulkMccssMode.Replace => "replace",
                BulkMccssMode.Add => "add",
                _ => "remove"
            };
            parts.Add($"MCCSS · {modeLabel} {_changes.MccssTypes.Count} type{(_changes.MccssTypes.Count == 1 ? "" : "s")}");
        }
        if (_changes.EnablePlanType) parts.Add($"plan type → {_changes.PlanType}");
        if (_changes.EnableMinistry) parts.Add($"team → {_changes.Ministry}");
        if (_changes.EnableOutcome)
        {
            var o = _changes.Outcome ?? "";
            var trimmed = o.Length > 18 ? o.Substring(0, 18) + "…" : o;
            parts.Add($"outcome → \"{trimmed}\"");
        }
        return parts;
    }

    private void Apply()
    {
        var n = Svc.ApplyBulkChanges(_changes);
        Toasts.Show(ToastKind.Success, $"Updated {n} commitment{(n == 1 ? "" : "s")}");
        Close();
    }

    private static string MoneyShort(decimal n) => "$" + n.ToString("N0");
}
