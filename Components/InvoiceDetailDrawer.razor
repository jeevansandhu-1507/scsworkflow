@inject InvoicingService Inv
@inject UserContextService UserCtx
@inject ToastService Toasts
@inject FundingCommitmentService Fc

<div class="full-overlay @(_open ? "open" : "")" @onclick="Close"></div>
<aside class="full-view @(_open ? "open" : "")" aria-hidden="@(_open ? "false" : "true")">
    @if (_invoice != null)
    {
        var inv = _invoice;
        <header class="fv-head">
            <div class="fv-head-left">
                <div class="fv-eyebrow">Invoice</div>
                <h2>@inv.Number</h2>
                <p class="fv-sub">
                    @inv.VendorName · @(inv.VendorType == VendorType.Isw ? "ISW" : "SP")
                    · for @inv.LinkedEntityName
                    · @inv.Date.ToString("MMM dd, yyyy")
                </p>
            </div>
            <div class="fv-head-right">
                @if (inv.Status == InvoiceStatus.Draft && UserCtx.IsVendor)
                {
                    <button class="btn primary" @onclick="SubmitInvoice">Submit</button>
                }
                @if (inv.Status == InvoiceStatus.Submitted && (UserCtx.IsFinance || UserCtx.IsAdmin))
                {
                    <button class="btn primary" @onclick="ApproveInvoice">Approve</button>
                    <button class="btn" style="color:var(--danger)" @onclick="RejectInvoice">Reject</button>
                }
                @if (inv.Status == InvoiceStatus.Approved && (UserCtx.IsFinance || UserCtx.IsAdmin))
                {
                    <button class="btn primary" @onclick="PayInvoice">Mark paid</button>
                }
                <button class="fv-close" @onclick="Close" aria-label="Close invoice detail">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false"><path d="M18 6 6 18M6 6l12 12" /></svg>
                </button>
            </div>
        </header>

        <div class="fv-body">
            <section class="fv-sec">
                <div class="fv-sec-head"><span class="fv-sec-num">1</span><h3>Summary</h3></div>
                <div class="fv-sec-body">
                    <div class="fv-field"><div class="lbl">Number</div><div class="val mono">@inv.Number</div></div>
                    <div class="fv-field"><div class="lbl">Status</div><div class="val"><span class="status-pill @InvClass(inv.Status)">@inv.Status</span></div></div>
                    <div class="fv-field"><div class="lbl">Vendor</div><div class="val">@inv.VendorName</div></div>
                    <div class="fv-field"><div class="lbl">Vendor Type</div><div class="val">@(inv.VendorType == VendorType.Isw ? "Independent Support Worker" : "Service Provider")</div></div>
                    <div class="fv-field"><div class="lbl">Linked</div><div class="val">@inv.LinkedEntityName <span class="muted" style="font-size:11px">(@(inv.Association == AssociationType.Client ? "Client" : "Project"))</span></div></div>
                    <div class="fv-field"><div class="lbl">FC reference</div><div class="val mono">@(inv.FcId ?? "—")</div></div>
                    <div class="fv-field"><div class="lbl">Issue date</div><div class="val mono">@inv.Date.ToString("MMM dd, yyyy")</div></div>
                    <div class="fv-field"><div class="lbl">Total</div><div class="val money">@inv.Total.ToString("C2")</div></div>
                </div>
                @if (!string.IsNullOrEmpty(inv.RejectionReason))
                {
                    <div style="padding:0 18px 16px">
                        <div class="modal-result error">Rejected: @inv.RejectionReason</div>
                    </div>
                }
            </section>

            <section class="fv-sec">
                <div class="fv-sec-head"><span class="fv-sec-num">2</span><h3>Line items (@inv.Lines.Count)</h3></div>
                <div style="overflow-x:auto">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Description</th>
                                @if (!IsInvoiceUnrestricted(inv))
                                {
                                    <th>Support type</th>
                                }
                                <th class="num">Qty</th>
                                <th class="num">Rate</th>
                                <th class="num">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ln in inv.Lines)
                            {
                                <tr>
                                    <td>@ln.Description</td>
                                    @if (!IsInvoiceUnrestricted(inv))
                                    {
                                        <td class="muted">@ln.SupportType</td>
                                    }
                                    <td class="num mono">@ln.Quantity.ToString("0.##")</td>
                                    <td class="num mono">@ln.Rate.ToString("C2")</td>
                                    <td class="num mono">@ln.Amount.ToString("C2")</td>
                                </tr>
                            }
                            <tr style="background:var(--brand-25);font-weight:600">
                                <td colspan="@(IsInvoiceUnrestricted(inv) ? 3 : 4)" class="num">Total</td>
                                <td class="num mono">@inv.Total.ToString("C2")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="fv-sec">
                <div class="fv-sec-head"><span class="fv-sec-num">3</span><h3>Audit history</h3></div>
                <EntityHistory EntityType="Invoice" EntityId="@inv.Id" />
            </section>
        </div>
    }
</aside>

@code {
    private bool _open;
    private Invoice? _invoice;

    private bool IsInvoiceUnrestricted(Invoice? inv)
    {
        if (inv == null || string.IsNullOrEmpty(inv.FcId)) return false;
        var fc = Fc.FindByCommitId(inv.FcId);
        return fc != null && fc.PlanType == "Unrestricted";
    }

    public bool IsOpen => _open;

    public void Open(string invoiceId)
    {
        _invoice = Inv.Invoices.FirstOrDefault(i => i.Id == invoiceId);
        _open = _invoice != null;
        StateHasChanged();
    }

    public void Close()
    {
        _open = false;
        _invoice = null;
        StateHasChanged();
    }

    private void SubmitInvoice()
    {
        if (_invoice == null) return;
        Inv.Submit(_invoice.Id);
        Toasts.Show(ToastKind.Success, $"{_invoice.Number} submitted.");
        StateHasChanged();
    }

    private void ApproveInvoice()
    {
        if (_invoice == null) return;
        Inv.Approve(_invoice.Id);
        Toasts.Show(ToastKind.Success, $"{_invoice.Number} approved.");
        StateHasChanged();
    }

    private void RejectInvoice()
    {
        if (_invoice == null) return;
        Inv.Reject(_invoice.Id, "Returned for revision.");
        Toasts.Show(ToastKind.Warning, $"{_invoice.Number} rejected.");
        StateHasChanged();
    }

    private void PayInvoice()
    {
        if (_invoice == null) return;
        Inv.MarkPaid(_invoice.Id);
        Toasts.Show(ToastKind.Success, $"{_invoice.Number} marked paid.");
        StateHasChanged();
    }

    private static string InvClass(InvoiceStatus s) => s switch
    {
        InvoiceStatus.Draft => "st-draft",
        InvoiceStatus.Submitted => "st-pending",
        InvoiceStatus.Approved => "st-approved",
        InvoiceStatus.Paid => "st-active",
        InvoiceStatus.Rejected => "st-rejected",
        _ => "st-draft"
    };
}
