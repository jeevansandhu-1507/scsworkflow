@inject NavigationManager Nav

<div class="sub-item @(IsActive() ? "active" : "")" @onclick="Go">@Label</div>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "";
    [Parameter, EditorRequired] public string Label { get; set; } = "";

    private bool IsActive()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        var qIdx = relative.IndexOf('?');
        if (qIdx >= 0) relative = relative.Substring(0, qIdx);
        return relative.Trim('/') == Href.Trim('/');
    }

    private void Go() => Nav.NavigateTo("" + Href);
}
