@inject NavigationManager Nav

<div class="nav-item @Dot @(IsActive() ? "active" : "")" @onclick="Go" style="cursor:pointer">
    <span class="dot"></span>@Label
</div>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public string Dot { get; set; } = "dot-home";

    private bool IsActive()
    {
        var uri = new Uri(Nav.Uri);
        var path = uri.AbsolutePath.Trim('/');
        return (Href == "" && (path == "" || path == "/")) || path == Href;
    }

    private void Go() => Nav.NavigateTo("/" + Href);
}
