@page "/funding-commitments/new"
@implements IDisposable
@inject FundingCommitmentService Fc
@inject ProjectService Projects
@inject ClientDirectoryService Clients
@inject VendorService Vendors
@inject PermanentFundingService Pf
@inject ActiveContextService Context
@inject UserContextService UserCtx
@inject ToastService Toasts
@inject NavigationManager Nav

<PageTitle>SCS Portal · New Funding Commitment</PageTitle>

<section class="page wizard-page @(IsWideStep() ? "wizard-page-wide" : "")">
    @if (Context.RequiresActive && !Context.HasActive)
    {
        <div class="empty-state">
            <div class="empty-title">No active client or project selected</div>
            <div class="empty-sub">Use <strong>Set Active Client</strong> in the top bar before creating a funding commitment.</div>
            <button class="btn primary" style="margin-top:14px" @onclick='() => Nav.NavigateTo("funding-commitments")'>Back</button>
        </div>
    }
    else
    {
        <div class="wiz-head">
            <div class="wiz-title">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><path d="M14 2v6h6" /></svg>
                <strong>New Funding Commitment</strong>
                <span class="muted" style="margin-left:8px">for @_draft.LinkedEntityDisplay · #@_draft.LinkedEntityId</span>
            </div>
            <div class="wiz-steps">
                @for (int i = 1; i <= TotalSteps; i++)
                {
                    var step = i;
                    <div class="wiz-step @(step == _step ? "current" : step < _step ? "done" : "")">
                        <div class="wiz-step-bubble" title="@GetStepsList()[step - 1]">@step</div>
                        @if (step < TotalSteps)
                        {
                            <div class="wiz-step-bar"></div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="wiz-body">
            @switch (CurrentStepName)
            {
                case "Initial Details": @StepInitial() break;
                case "Funder Selection": @StepFunderSelection() break;
                case "SCS Team Accountable": @StepScsTeam() break;
                case "Select Funding Types": @StepSelectFundingTypes() break;
                case "Service Line Allocation": @StepServiceLineAllocation() break;
                case "Vendor Assignment": @StepVendorAssignment() break;
                case "Plan Amount": @StepPlanAmount() break;
                case "File Upload": @StepFileUpload() break;
                case "Review & Submit": @StepReviewSubmit() break;
            }
        </div>

        <footer class="wiz-foot">
            <button class="btn" style="background:#d23a2c;color:#fff;border-color:#a52316" @onclick="Exit">✕ EXIT</button>
            <div style="flex:1"></div>
            @if (_step > 1)
            {
                <button class="btn" @onclick="Back">← BACK</button>
            }
            <button class="btn" @onclick="SaveDraft">⛶ SAVE DRAFT</button>
            @if (_step < TotalSteps)
            {
                <button class="btn primary" @onclick="Next" disabled="@(!CanAdvance())">NEXT →</button>
            }
            else
            {
                <button class="btn primary" @onclick="Submit" disabled="@(!CanAdvance())">SUBMIT FC →</button>
            }
        </footer>

        <ServiceLineSubform @ref="_subform"
                            IsRestricted="@(_draft.McsssPlanType == "Restricted")"
                            PlanTypes="_draft.McsssTypes"
                            TotalFunding="@((_draft.MainFunder == "MCCSS" || IsTransferPlan) ? _draft.TotalPlan : NonMccssPlanAmount)"
                            AlreadyCommitted="@AlreadyCommittedExcludingCurrent()"
                            OnSave="OnSubformSave"
                            OnCancel="OnSubformCancel" />
    }
</section>

@code {
    [SupplyParameterFromQuery] public string? permanentFundingCommitmentId { get; set; }

    private int _step = 1;
    private FcWizardDraft _draft = new();

    private ServiceLineSubform? _subform;

    // non-MCCSS state variables
    private decimal NonMccssPlanAmount { get; set; } = 0;
    private bool AssignAmountToVendor { get; set; } = false;

    private bool IsTransferPlan => _draft.FundingTypeChoice is "An In-Year MYSLP transfer plan" or "A plan for someone transferring from another region or agency";

    private List<string> GetStepsList()
    {
        var steps = new List<string> { "Initial Details", "Funder Selection" };
        if (_draft.MainFunder == "MCCSS" || IsTransferPlan)
        {
            steps.Add("SCS Team Accountable");
            steps.Add("Select Funding Types");
            if (_draft.McsssPlanType == "Restricted")
            {
                steps.Add("Service Line Allocation");
            }
            else
            {
                steps.Add("Vendor Assignment");
            }
        }
        else
        {
            steps.Add("Plan Amount");
            if (AssignAmountToVendor)
            {
                steps.Add("Vendor Assignment");
            }
        }
        steps.Add("File Upload");
        steps.Add("Review & Submit");
        return steps;
    }

    private int TotalSteps => GetStepsList().Count;
    private string CurrentStepName => GetStepsList().ElementAtOrDefault(_step - 1) ?? "";

    protected override void OnInitialized()
    {
        Context.OnChange += R;
        BindContext();
        
        if (!string.IsNullOrEmpty(permanentFundingCommitmentId))
        {
            _draft.PermanentFundingId = permanentFundingCommitmentId;
            _draft.FundingTypeChoice = "None of the above";
            var pfRecord = Pf.FindById(permanentFundingCommitmentId);
            if (pfRecord != null)
            {
                _draft.LinkedEntityId = pfRecord.LinkedEntityId;
                _draft.LinkedEntityDisplay = pfRecord.LinkedEntityName;
                _draft.Association = pfRecord.Association;
                _draft.MainFunder = pfRecord.FundingSource;
                _draft.PlanStart = pfRecord.EffectiveStart;
                _draft.PlanEnd = pfRecord.EffectiveEnd;
            }
        }
    }

    private void R() => InvokeAsync(StateHasChanged);

    private void BindContext()
    {
        if (!string.IsNullOrEmpty(permanentFundingCommitmentId)) return; // Bound via query parameter
        if (!Context.HasActive) return;
        if (Context.Kind == ActiveContextKind.Client)
        {
            _draft.Association = AssociationType.Client;
            _draft.LinkedEntityId = Context.ActiveClient!.EtoId;
            _draft.LinkedEntityDisplay = Context.ActiveClient.FullName;
        }
        else
        {
            _draft.Association = AssociationType.Project;
            _draft.LinkedEntityId = Context.ActiveProject!.Id;
            _draft.LinkedEntityDisplay = Context.ActiveProject.Name;
        }
    }

    // ---------- Step: Initial Details ----------
    private RenderFragment StepInitial() => @<text>
        <div class="wiz-note">In order to create a new funding commitment for your @(_draft.Association == AssociationType.Client ? "client" : "project"), you will need the following information. When, where, etc. Please ensure you have this information prior to proceeding.</div>

        @if (string.IsNullOrEmpty(permanentFundingCommitmentId))
        {
            <div class="wiz-row">
                <label class="wiz-q">What type of funding is this? <span class="req">*</span></label>
                @foreach (var ft in GetAllowedFundingTypeChoices())
                {
                    var ftv = ft;
                    <label class="wiz-radio">
                        <input type="radio" name="ftype" checked="@(_draft.FundingTypeChoice == ftv)" @onchange="() => OnFundingTypeChoiceChanged(ftv)" />
                        <span>@ft</span>
                    </label>
                }
            </div>
        }

        @if (_draft.FundingTypeChoice is "An In-Year MYSLP transfer plan" or "A plan for someone transferring from another region or agency")
        {
            <div class="wiz-row">
                <label class="wiz-q">Where does the person currently live? <span class="req">*</span></label>
                @foreach (var p in GetAllowedPlacements())
                {
                    var pv = p;
                    <label class="wiz-radio">
                        <input type="radio" name="place" checked="@(_draft.ResidentialPlacement == pv)" @onchange="() => { _draft.ResidentialPlacement = pv; ResolveAllGl(); }" />
                        <span>@p</span>
                    </label>
                }
            </div>
        }
        else if (_draft.FundingTypeChoice == "CSN Youth funding (for the current year)")
        {
            <div class="wiz-row">
                <label class="wiz-q">Living arrangement (for information purposes only) <span class="req">*</span></label>
                <div class="wiz-hint" style="margin-bottom:8px">This field is informational only and does not impact funding, approvals, or calculations.</div>
                @foreach (var la in Catalog.CsnLivingArrangements)
                {
                    var lav = la;
                    <label class="wiz-radio">
                        <input type="radio" name="csn_la" checked="@(_draft.CsnLivingArrangement == lav)" @onchange="() => { _draft.CsnLivingArrangement = lav; }" />
                        <span>@la</span>
                    </label>
                }
            </div>
        }

        <div class="wiz-row">
            <label class="wiz-q">What is the start and end date of this plan? <span class="req">*</span></label>
            <div class="wiz-hint">Dates must be within a fiscal year (April to March). To allocate funding beyond March, complete a new form for the next fiscal year.</div>
            <div class="wiz-2col">
                <div class="modal-row">
                    <label class="modal-lbl">Start date</label>
                    <input type="date" class="modal-input"
                           value="@_draft.PlanStart?.ToString("yyyy-MM-dd")"
                           @onchange="@(e => _draft.PlanStart = DateTime.TryParse(e.Value?.ToString(), out var dt) ? dt : null)" />
                </div>
                <div class="modal-row">
                    <label class="modal-lbl">End date</label>
                    <input type="date" class="modal-input"
                           value="@_draft.PlanEnd?.ToString("yyyy-MM-dd")"
                           @onchange="@(e => _draft.PlanEnd = DateTime.TryParse(e.Value?.ToString(), out var dt) ? dt : null)" />
                </div>
            </div>
        </div>

        <div class="wiz-row">
            <label class="wiz-q">Please specify below the client's current situation and the anticipated outcome of this funding commitment. <span class="req">*</span></label>
            <textarea class="modal-input wiz-textarea" placeholder="Enter your answer" @bind="_draft.CurrentSituationOutcome"></textarea>
        </div>

        <div class="wiz-row">
            <label class="wiz-q">Please specify below what the impact will be to the client if this funding commitment is not approved and list the alternative funding sources you have explored. <span class="req">*</span></label>
            <textarea class="modal-input wiz-textarea" placeholder="Enter your answer" @bind="_draft.ImpactAndAlternatives"></textarea>
        </div>
    </text>;

    // ---------- Step: Funder Selection ----------
    private RenderFragment StepFunderSelection() => @<text>
        <div class="wiz-row">
            <label class="wiz-q">Please select the plan's main funder. <span class="req">*</span></label>
            @foreach (var mf in GetAllowedMainFunders())
            {
                var mfv = mf;
                var isForced = IsFunderSelectionForced();
                if (isForced && mfv != "MCCSS") continue;
                <label class="wiz-radio">
                    @if (isForced)
                    {
                        <input type="radio" name="mfunder" disabled checked />
                    }
                    else
                    {
                        <input type="radio" name="mfunder" checked="@(_draft.MainFunder == mfv)" @onchange="() => OnMainFunderChanged(mfv)" />
                    }
                    <span style="@(isForced ? "opacity:0.6" : "")">@mf</span>
                </label>
            }
        </div>

        @if (!string.IsNullOrEmpty(_draft.MainFunder))
        {
            <div class="wiz-row">
                <label class="wiz-q">Additional Funder Selection</label>
                <div class="wiz-chip-tray">
                    @foreach (var af in _draft.AdditionalFunders)
                    {
                        var afv = af;
                        <span class="wiz-chip selected">
                            @af
                            <button @onclick="() => _draft.AdditionalFunders.Remove(afv)">×</button>
                        </span>
                    }
                </div>
                @{
                    var pickable = GetAllowedAdditionalFunders().Where(x => !_draft.AdditionalFunders.Contains(x) && x != _draft.MainFunder).ToList();
                }
                @if (pickable.Any())
                {
                    <div class="wiz-chip-tray" style="margin-top:8px">
                        @foreach (var af in pickable)
                        {
                            var afv = af;
                            <button class="wiz-chip-pick" @onclick="() => _draft.AdditionalFunders.Add(afv)">+ @af</button>
                        }
                    </div>
                }
            </div>
        }
    </text>;

    private void OnMainFunderChanged(string mainFunder)
    {
        _draft.MainFunder = mainFunder;
        _draft.AdditionalFunders.Remove(mainFunder);
        _draft.McsssTypes.Clear();
        _draft.McsssAmounts.Clear();
        _draft.McsssRestrictions.Clear();
        _draft.Services.Clear();
        NonMccssPlanAmount = 0;
        AssignAmountToVendor = false;

        if (IsTransferPlan)
        {
            _draft.McsssPlanType = "Restricted";
            _draft.ScsTeam = "Residential And Community Services (RCS)";
            if (mainFunder == "Passport One (Family Services Ontario)")
            {
                _draft.McsssTypes.Add("Passport Funding");
                _draft.McsssAmounts["Passport Funding"] = 0;
                _draft.McsssRestrictions["Passport Funding"] = "Restricted";
            }
            else
            {
                _draft.McsssTypes.Add("MCCSS Fiscal Residential Funding Allocation");
                _draft.McsssAmounts["MCCSS Fiscal Residential Funding Allocation"] = 0;
                _draft.McsssRestrictions["MCCSS Fiscal Residential Funding Allocation"] = "Restricted";
            }
        }
    }

    private IEnumerable<string> GetAllowedMainFunders()
    {
        if (_draft.FundingTypeChoice == "An In-Year MYSLP transfer plan" ||
            _draft.FundingTypeChoice == "CSN Youth funding (for the current year)")
        {
            return new[] { "MCCSS" };
        }
        if (_draft.FundingTypeChoice == "A plan for someone transferring from another region or agency" ||
            _draft.FundingTypeChoice == "Temporary funding (in-year support)")
        {
            return new[] { "MCCSS", "Passport One (Family Services Ontario)" };
        }
        var isAdmin = UserCtx?.IsAdmin == true;
        return Catalog.MainFunderChoices.Where(f => isAdmin || (f != "SSAH" && f != "CHEO" && f != "ODSP"));
    }

    private IEnumerable<string> GetAllowedAdditionalFunders()
    {
        if (_draft.FundingTypeChoice == "An In-Year MYSLP transfer plan")
        {
            return new[] { "Passport One (Family Services Ontario)" };
        }
        if (_draft.FundingTypeChoice == "A plan for someone transferring from another region or agency" ||
            _draft.FundingTypeChoice == "Temporary funding (in-year support)")
        {
            return new[] { "MCCSS", "Passport One (Family Services Ontario)" };
        }
        if (_draft.FundingTypeChoice == "CSN Youth funding (for the current year)")
        {
            return new[] { "SSAH", "CHEO" };
        }
        return Catalog.AddlFunderChoices;
    }

    private IEnumerable<string> GetAllowedPlacements()
    {
        return Catalog.ResidentialPlacements;
    }

    private bool IsFunderSelectionForced()
    {
        return _draft.FundingTypeChoice == "An In-Year MYSLP transfer plan" ||
               _draft.FundingTypeChoice == "CSN Youth funding (for the current year)";
    }

    private void OnFundingTypeChoiceChanged(string choice)
    {
        _draft.FundingTypeChoice = choice;

        if (choice == "An In-Year MYSLP transfer plan")
        {
            _draft.MainFunder = "MCCSS";
            _draft.AdditionalFunders.Clear();
            _draft.McsssPlanType = "Restricted";
            _draft.ScsTeam = "Residential And Community Services (RCS)";
            _draft.McsssTypes = new List<string> { "MCCSS Fiscal Residential Funding Allocation" };
            _draft.McsssAmounts = new Dictionary<string, decimal> { ["MCCSS Fiscal Residential Funding Allocation"] = 0 };
            _draft.McsssRestrictions = new Dictionary<string, string> { ["MCCSS Fiscal Residential Funding Allocation"] = "Restricted" };
            _draft.CsnLivingArrangement = "";
        }
        else if (choice == "A plan for someone transferring from another region or agency")
        {
            _draft.MainFunder = "MCCSS";
            _draft.AdditionalFunders.Clear();
            _draft.McsssPlanType = "Restricted";
            _draft.ScsTeam = "Residential And Community Services (RCS)";
            _draft.McsssTypes = new List<string> { "MCCSS Fiscal Residential Funding Allocation" };
            _draft.McsssAmounts = new Dictionary<string, decimal> { ["MCCSS Fiscal Residential Funding Allocation"] = 0 };
            _draft.McsssRestrictions = new Dictionary<string, string> { ["MCCSS Fiscal Residential Funding Allocation"] = "Restricted" };
            _draft.CsnLivingArrangement = "";
        }
        else if (choice == "CSN Youth funding (for the current year)")
        {
            _draft.MainFunder = "MCCSS";
            _draft.AdditionalFunders.Clear();
            _draft.McsssPlanType = "Restricted";
            _draft.ScsTeam = "Residential And Community Services (RCS)";
            _draft.McsssTypes = new List<string> { "Temporary Funding Allocation - Complex Special Needs (CSN)" };
            _draft.McsssAmounts = new Dictionary<string, decimal> { ["Temporary Funding Allocation - Complex Special Needs (CSN)"] = 0 };
            _draft.McsssRestrictions = new Dictionary<string, string> { ["Temporary Funding Allocation - Complex Special Needs (CSN)"] = "Restricted" };
            _draft.ResidentialPlacement = "";
        }
        else
        {
            _draft.MainFunder = "MCCSS";
            _draft.AdditionalFunders.Clear();
            _draft.McsssPlanType = "Restricted";
            _draft.ScsTeam = "";
            _draft.McsssTypes.Clear();
            _draft.McsssAmounts.Clear();
            _draft.McsssRestrictions.Clear();
            _draft.ResidentialPlacement = "";
            _draft.CsnLivingArrangement = "";
        }
        ResolveAllGl();
    }

    // ---------- Step: SCS Team Accountable ----------
    private RenderFragment StepScsTeam() => @<text>
        <h2 class="wiz-h2">You selected @_draft.MainFunder as main funder</h2>
        <div class="wiz-row">
            <label class="wiz-q">Which SCS team is accountable for this funding commitment? <span class="req">*</span></label>
            <select class="modal-input" @bind="_draft.ScsTeam">
                <option value="">Select your answer</option>
                @foreach (var t in GetAllowedScsTeams()) { <option value="@t">@t</option> }
            </select>
        </div>
    </text>;

    // ---------- Step: Select Funding Types (MCCSS) ----------
    private RenderFragment StepSelectFundingTypes() => @<text>
        <div class="ft-select-card">
            <h3 class="ft-select-h">Select Funding Types</h3>

            <label class="ft-select-lbl">FUNDING TYPE</label>
            <div class="ft-select-chips">
                @foreach (var t in _draft.McsssTypes)
                {
                    var tv = t;
                    <span class="ft-chip-selected">
                        @t
                        <button @onclick="() => RemoveMcsssType(tv)" title="Remove">×</button>
                    </span>
                }
                @{
                    var pickableFt = GetAvailableFundingTypes().Where(x => !_draft.McsssTypes.Contains(x)).ToList();
                }
                @if (pickableFt.Any())
                {
                    <select class="ft-chip-add" value=""
                            @onchange="@(e => AddMcsssTypeIfNew(e.Value?.ToString()))">
                        <option value="">+ Add funding type…</option>
                        @foreach (var t in pickableFt)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                }
            </div>

            @if (_draft.McsssTypes.Count > 0)
            {
                <div class="ft-select-rows" style="margin-top:16px">
                    @foreach (var t in _draft.McsssTypes)
                    {
                        var tv = t;
                        <div class="ft-select-row" style="display:flex;gap:12px;margin-bottom:12px">
                            <div style="flex:2">
                                <div class="ft-srow-lbl">@tv.ToUpper()</div>
                                <input class="modal-input" readonly value="@tv" />
                            </div>
                            <div style="flex:1">
                                <div class="ft-srow-lbl">FUNDING, $</div>
                                <input type="number" min="0" class="modal-input" placeholder="$ 0"
                                       value="@(_draft.McsssAmounts.TryGetValue(tv, out var v) ? v.ToString("0") : "")"
                                       @onchange="@(e => SetMcsssAmount(tv, e.Value?.ToString()))" />
                            </div>
                        </div>
                    }
                </div>

                <div class="wiz-row" style="margin-top:18px">
                    <label class="wiz-q">What is the MCCSS plan type? <span class="req">*</span></label>
                    <select class="modal-input" @bind="_draft.McsssPlanType">
                        <option value="Restricted">Restricted</option>
                        <option value="Unrestricted">Unrestricted</option>
                    </select>
                </div>

                <div class="ft-select-total" style="text-align:right;font-size:16px;font-weight:600;margin-top:12px">
                    <span class="ft-total-lbl">Total Plan Amount:</span>
                    <span class="ft-total-val" style="color:var(--brand-700)">@_draft.TotalPlan.ToString("C0")</span>
                </div>
            }
        </div>
    </text>;

    // ---------- Step: Service Line Allocation (Restricted) ----------
    private RenderFragment StepServiceLineAllocation() => @<text>
        @{
            var planTotal = _draft.TotalPlan;
            var preHst = _draft.Services.Sum(s => s.LineTotal);
            var hstUnrecoverable = _draft.Services.Where(s => s.IncludeHst).Sum(s => s.LineTotalWithHst - s.LineTotal);
            var commitmentImpact = preHst + hstUnrecoverable;
            var remainingAvail = planTotal - commitmentImpact;
        }

        <div class="ft-summary" style="margin-bottom:16px">
            <div class="ft-summary-head" style="font-weight:600;margin-bottom:8px">New Funding Commitment</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:13px">
                <div>Planned Service Amount (pre-HST): <strong class="mono">@preHst.ToString("C2")</strong></div>
                <div>Calculated Unrecoverable HST: <strong class="mono">@hstUnrecoverable.ToString("C2")</strong></div>
                <div>Total Commitment Impact: <strong class="mono">@commitmentImpact.ToString("C2")</strong></div>
                <div>Remaining Funding Available: <strong class="mono" style="color:@(remainingAvail < 0 ? "var(--danger)" : "var(--success)")">@remainingAvail.ToString("C2")</strong></div>
            </div>
        </div>

        @if (_draft.McsssTypes.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-title">No funding types selected</div>
                <div class="empty-sub">Go back to step 4 and pick at least one funding type.</div>
            </div>
        }
        else
        {
            @foreach (var t in _draft.McsssTypes)
            {
                var tv = t;
                var planAmt = _draft.McsssAmounts.TryGetValue(tv, out var pa) ? pa : 0;
                var lines = _draft.Services.Where(s => s.Plan == tv).ToList();
                var sectionCommit = lines.Sum(s => s.LineTotalWithHst);

                <div class="ft-section" style="border:1px solid var(--border);border-radius:4px;margin-bottom:16px;background:#fff">
                    <div class="ft-section-head" style="padding:12px 16px;background:#f9f9f9;display:flex;justify-content:space-between;align-items:center;font-weight:600;border-bottom:1px solid var(--border)">
                        <span>Funding Type — @tv</span>
                        <span style="color:@(sectionCommit > planAmt ? "var(--danger)" : "var(--brand-700)")">
                            @sectionCommit.ToString("C2") / $@planAmt.ToString("N0")
                        </span>
                    </div>
                    <div style="padding:12px">
                        @ServiceTableHeader()
                        @foreach (var ln in lines)
                        {
                            @ServiceRow(ln)
                        }
                        <button class="btn" style="margin-top:8px" @onclick="() => AddLineForPlan(tv)">+ Add Line</button>
                    </div>
                </div>
            }
        }
    </text>;

    private RenderFragment ServiceTableHeader() => @<text>
        <div style="display:grid;grid-template-columns:2.5fr 1.5fr 2fr 1fr 1fr 1fr 0.5fr 1.5fr 1fr;gap:6px;font-size:11px;font-weight:600;color:var(--ink-3);border-bottom:1px solid var(--border);padding-bottom:6px;margin-bottom:6px">
            <div>SERVICE TYPE</div>
            <div>PROVIDER</div>
            <div>VENDOR NAME</div>
            <div>RATE</div>
            <div>UNIT</div>
            <div>UNITS</div>
            <div>HST?</div>
            <div>TOTAL</div>
            <div></div>
        </div>
    </text>;

    private RenderFragment ServiceRow(ServiceLine ln) => @<text>
        <div style="display:grid;grid-template-columns:2.5fr 1.5fr 2fr 1fr 1fr 1fr 0.5fr 1.5fr 1fr;gap:6px;align-items:center;margin-bottom:6px">
            <div>
                <select class="modal-input" style="font-size:12px;padding:4px" value="@ln.Name" @onchange="@(e => { ln.Name = e.Value?.ToString() ?? ""; ResolveGlForLine(ln); })">
                    <option value="">Select service type</option>
                    @foreach (var s in GetCompatibleSupportTypesForStep(ln.Plan)) { <option value="@s">@s</option> }
                </select>
                @if (ln.GlCode > 0)
                {
                    <div style="font-size:10px;color:var(--brand-700);margin-top:2px;font-family:monospace" title="@ln.GlName">
