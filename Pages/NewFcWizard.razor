    // ---------- Service-line helpers ----------
    private ServiceLine? _notesPopoverLine;

    private void AddLineForPlan(string plan)
    {
        _draft.Services.Add(new ServiceLine
        {
            Name = "",
            Plan = plan,
            Provider = "Independent Support Worker (ISW)",
            Vendor = "Unassigned",
            Unit = "Hour",
            Rate = 0,
            Units = 0,
            HasMaxRate = true,
            HasMaxUnits = true
        });
    }

    private void RemoveLine(ServiceLine line)
    {
        _draft.Services.Remove(line);
        if (_notesPopoverLine == line) _notesPopoverLine = null;
    }

    private void SetLineRate(ServiceLine ln, string? value) =>
        ln.Rate = decimal.TryParse(value, out var n) ? n : 0;

    private void SetLineUnits(ServiceLine ln, string? value) =>
        ln.Units = decimal.TryParse(value, out var n) ? n : 0;

    private void SetPlanningBase(ServiceLine ln, string? value) =>
        ln.PlanningBaseAmount = decimal.TryParse(value, out var n) ? n : (decimal?)null;

    private void SetProvider(ServiceLine ln, string? value) =>
        ln.Provider = value ?? "Independent Support Worker (ISW)";

    private void OpenNotePopover(ServiceLine ln) =>
        _notesPopoverLine = _notesPopoverLine == ln ? null : ln;

    private void CloseNotePopover() => _notesPopoverLine = null;

    private void ResolveGlForLine(ServiceLine ln)
    {
        string fundingStatus = "Temporary";
        if (_draft.FundingTypeChoice is "An In-Year MYSLP transfer plan" or "A plan for someone transferring from another region or agency")
        {
            fundingStatus = "Permanent";
        }
        else if (_draft.FundingTypeChoice == "CSN Youth funding (for the current year)")
        {
            fundingStatus = "Temporary";
        }
        else
        {
            var normalizedFunding = GlMappingService.NormalizeFundingType(ln.Plan);
            var mappingRow = GlMappingService.CommitmentMappings.FirstOrDefault(m => m.FundingType.Equals(normalizedFunding, StringComparison.OrdinalIgnoreCase));
            fundingStatus = mappingRow?.FundingStatus ?? "Temporary";
        }

        string? placement = null;
        if (fundingStatus == "Permanent")
        {
            placement = _draft.ResidentialPlacement;
        }

        var glResult = GlMappingService.GetGlMappingForCommitment(ln.Plan, _draft.McsssPlanType, fundingStatus, ln.Name, placement);
        if (glResult != null)
        {
            ln.GlCode = glResult.GlCode;
            ln.GlName = glResult.GlName;
            ln.AccountId = glResult.AccountId;
        }
        else
        {
            ln.GlCode = 0;
            ln.GlName = "";
            ln.AccountId = "";
        }
    }

    private IEnumerable<string> GetAllowedFundingTypeChoices()
    {
        if (Context.HasActive && Context.Kind == ActiveContextKind.Client && Context.ActiveClient != null)
        {
            var status = Context.ActiveClient.FundingStatus;
            if (!status.Equals("Permanent", StringComparison.OrdinalIgnoreCase) && 
                !status.Equals("Pending Ministry Approval", StringComparison.OrdinalIgnoreCase))
            {
                return Catalog.FundingTypeChoices.Where(c => c == "Temporary funding (in-year support)");
            }
        }
        return Catalog.FundingTypeChoices;
    }

    private IEnumerable<string> GetAllowedScsTeams()
    {
        if (_draft.FundingTypeChoice == "Temporary funding (in-year support)")
        {
            return new[]
            {
                "Adult Case Management (ACM)",
                "Children's Case Management (CCM)",
                "Residential And Community Services (RCS)",
                "Program Supervisor (Special Approver)"
            };
        }
        return new[] { "Residential And Community Services (RCS)", "Program Supervisor (Special Approver)" };
    }

    private IEnumerable<string> GetAvailableFundingTypes()
    {
        if (_draft.FundingTypeChoice is "An In-Year MYSLP transfer plan" or "A plan for someone transferring from another region or agency")
        {
            return new[]
            {
                "MCCSS Fiscal Residential Funding Allocation",
                "MCCSS Fiscal Community Participation Funding Allocation",
                "Passport Funding"
            };
        }
        if (_draft.FundingTypeChoice == "CSN Youth funding (for the current year)")
        {
            return new[]
            {
                "Temporary Funding Allocation - Complex Special Needs (CSN)",
                "Temporary Funding Allocation - Community Enhancement (CEF)"
            };
        }
        return Catalog.MccssFundingTypeChoices;
    }

    private IEnumerable<string> GetCompatibleSupportTypesForStep(string plan)
    {
        var allCompatible = GlMappingService.GetCompatibleSupportTypes(plan, _draft.McsssPlanType);
        if (_draft.McsssPlanType == "Unrestricted")
        {
            return allCompatible;
        }

        var normalizedPlan = GlMappingService.NormalizeFundingType(plan);

        if (_draft.FundingTypeChoice is "An In-Year MYSLP transfer plan" or "A plan for someone transferring from another region or agency")
        {
            var isNonePlacement = string.IsNullOrEmpty(_draft.ResidentialPlacement) || 
                                  _draft.ResidentialPlacement.Equals("None of the above", StringComparison.OrdinalIgnoreCase);

            if (normalizedPlan.Equals("MCCSS Fiscal Community Participation Funding Allocation", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "Centre Based Day Programming",
                    "Structured Community Activities",
                    "Structured Seasonal Programs",
                    "Client Travel"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
            else if (normalizedPlan.Equals("Passport Program", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "Daily Living Support",
                    "Individualized Staffing",
                    "In Home Respite",
                    "Out of Home Respite",
                    "Centre Based Day Programming",
                    "Structured Community Activities",
                    "Structured Seasonal Programs",
                    "Live Events, Admissions & Tickets",
                    "Client Travel"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
            else if (normalizedPlan.Equals("MCCSS Fiscal Residential Funding Allocation", StringComparison.OrdinalIgnoreCase))
            {
                if (isNonePlacement)
                {
                    var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                    {
                        "Prescription Medication/Supplies",
                        "Presciption Medication/Supplies"
                    };
                    return allCompatible.Where(x => allowed.Contains(x));
                }
                else
                {
                    var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                    {
                        "Daily Living Support",
                        "Individualized Staffing",
                        "Clinical/Behaviour Supports",
                        "Prescription Medication/Supplies",
                        "Presciption Medication/Supplies",
                        "Client Travel"
                    };
                    return allCompatible.Where(x => allowed.Contains(x));
                }
            }
        }

        if (_draft.FundingTypeChoice == "CSN Youth funding (for the current year)")
        {
            if (normalizedPlan.Equals("Temporary Funding  Allocation- Community Enhancement (CEF)", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "Prescription Medication/Supplies",
                    "Presciption Medication/Supplies"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }

            var allowedCsn = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
            {
                "Daily Living Support",
                "Individualized Staffing",
                "In Home Respite",
                "Out of Home Respite",
                "Nursing Care",
                "Clinical/Behaviour Supports",
                "Assessment",
                "Assessments",
                "Prescription Medication/Supplies",
                "Presciption Medication/Supplies",
                "Structured Community Activities",
                "Structured Seasonal Programs",
                "Client Travel",
                "Parent Accommodation (Standard Room Only)",
                "Parent Travel",
                "Support Worker Travel"
            };
            return allCompatible.Where(x => allowedCsn.Contains(x));
        }

        if (_draft.FundingTypeChoice == "Temporary funding (in-year support)")
        {
            if (normalizedPlan.Equals("Historical Respite Funding Allocation", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "In Home Respite",
                    "Out of Home Respite",
                    "Centre Based Day Programming",
                    "Structured Community Activities",
                    "Structured Seasonal Programs",
                    "Client Travel"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
            else if (normalizedPlan.Equals("MCCSS Fiscal Community Participation Funding Allocation", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "Fiscal Community Participation Pressure",
                    "Base Increase Adjustment",
                    "Permanent Compensation Enhancement",
                    "Block Program Funding Subsidy"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
            else if (normalizedPlan.Equals("MCCSS Fiscal Residential Funding Allocation", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "Fiscal Residential Pressure",
                    "OPR Fire Code Reimbursement",
                    "Admin Fee - Welcome Home",
                    "Base Increase Adjustment",
                    "Permanent Compensation Enhancement"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
            else if (normalizedPlan.Equals("Passport Program", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "Passport Administration"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
            else if (normalizedPlan.Equals("Temporary Funding -Autism Spectrum Disorder (ASD) Allocation", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "Block Program Funding Subsidy",
                    "In Home Respite",
                    "Out of Home Respite",
                    "Structured Community Activities",
                    "Structured Seasonal Programs",
                    "Client Travel"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
            else if (normalizedPlan.Equals("Temporary Flexible Funding  Allocation (Adult) - English", StringComparison.OrdinalIgnoreCase) ||
                     normalizedPlan.Equals("Temporary Flexible Funding  Allocation (Adult) - French", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "In Home Respite",
                    "Out of Home Respite",
                    "Centre Based Day Programming",
                    "Structured Community Activities",
                    "Structured Seasonal Programs",
                    "Client Travel"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
            else if (normalizedPlan.Equals("Temporary Funding  Allocation- Community Enhancement (CEF)", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "In Home Respite",
                    "Out of Home Respite",
                    "Structured Community Activities",
                    "Structured Seasonal Programs",
                    "Client Travel"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
            else if (normalizedPlan.Equals("Temporary Funding Allocation (Adult) - English", StringComparison.OrdinalIgnoreCase) ||
                     normalizedPlan.Equals("Temporary Funding Allocation (Adult) - French", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "In Home Respite",
                    "Out of Home Respite",
                    "Centre Based Day Programming",
                    "Structured Community Activities",
                    "Structured Seasonal Programs",
                    "Client Travel"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
            else if (normalizedPlan.Equals("Temporary Funding Allocation - Children's", StringComparison.OrdinalIgnoreCase))
            {
                var allowed = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                {
                    "In Home Respite",
                    "Out of Home Respite",
                    "Structured Community Activities",
                    "Structured Seasonal Programs",
                    "Client Travel"
                };
                return allCompatible.Where(x => allowed.Contains(x));
            }
        }

        return allCompatible;
    }

    private void ResolveAllGl()
    {
        foreach (var ln in _draft.Services)
        {
            ResolveGlForLine(ln);
        }
    }

    private void OnSubformSave(ServiceLine saved) { }
    private void OnSubformCancel() { }
    private decimal AlreadyCommittedExcludingCurrent() => _draft.Services.Sum(s => s.LineTotal);
    private bool IsWideStep() => CurrentStepName == "Service Line Allocation" || CurrentStepName == "Vendor Assignment";

    // ---------- Step 4 chip helpers ----------
    private void AddMcsssType(string t)
    {
        if (string.IsNullOrEmpty(t) || _draft.McsssTypes.Contains(t)) return;
        _draft.McsssTypes.Add(t);
        if (!_draft.McsssAmounts.ContainsKey(t)) _draft.McsssAmounts[t] = 0;
        if (!_draft.McsssRestrictions.ContainsKey(t)) _draft.McsssRestrictions[t] = "Restricted";
    }

    private void AddMcsssTypeIfNew(string? t)
    {
        if (!string.IsNullOrEmpty(t)) AddMcsssType(t);
    }

    private void RemoveMcsssType(string t)
    {
        _draft.McsssTypes.Remove(t);
        _draft.McsssAmounts.Remove(t);
        _draft.McsssRestrictions.Remove(t);
        // Also remove service lines that referenced this type
        _draft.Services.RemoveAll(s => s.Plan == t);
    }

    private void SetMcsssAmount(string t, string? value)
    {
        decimal.TryParse(value, out var v);
        _draft.McsssAmounts[t] = v;
    }

    // ---------- Step gating ----------
    private bool CanAdvance()
    {
        var steps = GetStepsList();
        var curStep = steps.ElementAtOrDefault(_step - 1);
        return curStep switch
        {
            "Initial Details" => !string.IsNullOrEmpty(_draft.FundingTypeChoice)
                  && (_draft.FundingTypeChoice is not ("An In-Year MYSLP transfer plan" or "A plan for someone transferring from another region or agency") || !string.IsNullOrEmpty(_draft.ResidentialPlacement))
                  && (_draft.FundingTypeChoice != "CSN Youth funding (for the current year)" || !string.IsNullOrEmpty(_draft.CsnLivingArrangement))
                  && _draft.PlanStart.HasValue && _draft.PlanEnd.HasValue
                  && !string.IsNullOrWhiteSpace(_draft.CurrentSituationOutcome)
                  && !string.IsNullOrWhiteSpace(_draft.ImpactAndAlternatives),
            "Funder Selection" => !string.IsNullOrEmpty(_draft.MainFunder),
            "SCS Team Accountable" => !string.IsNullOrEmpty(_draft.ScsTeam),
            "Select Funding Types" => _draft.McsssTypes.Count > 0 && _draft.McsssTypes.All(t => _draft.McsssAmounts.TryGetValue(t, out var v) && v > 0),
            "Service Line Allocation" => _draft.Services.Count > 0 && _draft.Services.All(s => !string.IsNullOrEmpty(s.Name)),
            "Vendor Assignment" => _draft.Services.Count > 0 && _draft.Services.All(s => !string.IsNullOrEmpty(s.Vendor)),
            "Plan Amount" => NonMccssPlanAmount > 0,
            "File Upload" => true,
            "Review & Submit" => true,
            _ => false
        };
    }

    private void Next() { if (CanAdvance() && _step < TotalSteps) { _step++; ResolveAllGl(); } }
    private void Back() { if (_step > 1) { _step--; ResolveAllGl(); } }

    private void Exit()
    {
        Nav.NavigateTo("funding-commitments");
    }

    private void PrepareDraftForSave()
    {
        if (_draft.MainFunder != "MCCSS" && !IsTransferPlan)
        {
            _draft.McsssTypes = new List<string> { _draft.MainFunder };
            _draft.McsssAmounts = new Dictionary<string, decimal> { [_draft.MainFunder] = NonMccssPlanAmount };
            _draft.McsssPlanType = "Unrestricted";
            if (!AssignAmountToVendor)
            {
                _draft.Services = new List<ServiceLine>
                {
                    new ServiceLine
                    {
                        Name = "Unrestricted Allocation",
                        Plan = _draft.MainFunder,
                        Provider = "Independent Support Worker (ISW)",
                        Vendor = "Unassigned",
                        Unit = "One-time",
                        Rate = NonMccssPlanAmount,
                        Units = 1
                    }
                };
            }
        }
    }

    private void SaveDraft()
    {
        PrepareDraftForSave();
        var id = Fc.CreateFromWizard(_draft, submitOnFinish: false);
        Toasts.Show(ToastKind.Success, $"Draft FC {id} saved");
        Nav.NavigateTo("funding-commitments");
    }

    private void Submit()
    {
        PrepareDraftForSave();
        var id = Fc.CreateFromWizard(_draft, submitOnFinish: _draft.SubmitOnFinish);
        Toasts.Show(ToastKind.Success, _draft.SubmitOnFinish ? $"FC {id} submitted for Special Approval" : $"Draft FC {id} saved");
        Nav.NavigateTo("funding-commitments");
    }

    public void Dispose()
    {
        Context.OnChange -= R;
    }
}
