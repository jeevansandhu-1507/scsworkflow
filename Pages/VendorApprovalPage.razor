@page "/vendor-approval"
@implements IDisposable
@inject VendorService Vendors
@inject FundingCommitmentService Fc
@inject UserContextService UserCtx
@inject ToastService Toasts
@inject LocaleService L
@inject NavigationManager Nav

<PageTitle>SCS Portal · Vendor Approval</PageTitle>

<section class="page">
    @if (!UserCtx.IsFinance && !UserCtx.IsAdmin)
    {
        <div class="empty-state">
            <div class="empty-title">Finance only</div>
            <div class="empty-sub">Vendor profile approvals are managed by the SCS Finance team.</div>
            <button class="btn primary" style="margin-top:14px" @onclick='() => Nav.NavigateTo("/")'>Back to dashboard</button>
        </div>
    }
    else
    {
        var pending = Vendors.Pending().ToList();
        var approved = Vendors.Approved().ToList();
        var rejected = Vendors.Rejected().ToList();
        var currentList = _tab switch
        {
            "approved" => approved,
            "rejected" => rejected,
            _ => pending
        };

        <div class="fcl-head">
            <h1 class="fcl-title">🧾 Vendor Approval</h1>
        </div>

        <div class="page-header" style="margin-bottom:14px">
            <div class="stat-strip" style="grid-template-columns:repeat(4,minmax(120px,1fr))">
                <div class="stat stat-money-main" @onclick='() => _tab = "pending"'>
                    <div class="lbl">Pending</div>
                    <div class="v">@pending.Count</div>
                    <div class="sub">awaiting your approval</div>
                </div>
                <div class="stat" @onclick='() => _tab = "approved"'>
                    <div class="lbl">Approved</div>
                    <div class="v">@approved.Count</div>
                    <div class="sub">active in the directory</div>
                </div>
                <div class="stat" @onclick='() => _tab = "rejected"'>
                    <div class="lbl">Rejected</div>
                    <div class="v">@rejected.Count</div>
                    <div class="sub">declined profiles</div>
                </div>
                <div class="stat">
                    <div class="lbl">Total profiles</div>
                    <div class="v">@Vendors.Vendors.Count</div>
                    <div class="sub">across all statuses</div>
                </div>
            </div>
        </div>

        <div class="fcl-card">
            <div class="fcl-card-head">
                <div class="fcl-card-title">Vendor directory</div>
                <div class="fcl-card-actions">
                    <button class="btn fcl-add" @onclick="OpenNewVendor">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" /></svg>
                        REGISTER VENDOR
                    </button>
                    <div class="pf-tabs">
                        <button class="pf-tab @(_tab == "pending" ? "active" : "")" @onclick='() => _tab = "pending"'>
                            PENDING <span class="pf-tab-ct">@pending.Count</span>
                        </button>
                        <button class="pf-tab @(_tab == "approved" ? "active" : "")" @onclick='() => _tab = "approved"'>
                            APPROVED <span class="pf-tab-ct">@approved.Count</span>
                        </button>
                        <button class="pf-tab @(_tab == "rejected" ? "active" : "")" @onclick='() => _tab = "rejected"'>
                            REJECTED <span class="pf-tab-ct">@rejected.Count</span>
                        </button>
                    </div>
                </div>
            </div>

            <div class="fcl-meta">
                Showing <strong>@currentList.Count</strong> @_tab vendor@(currentList.Count == 1 ? "" : "s")
            </div>

            <div class="fcl-table-wrap">
                <table class="fcl-table">
                    <thead>
                        <tr>
                            <th>Vendor</th>
                            <th>Type</th>
                            <th>Contact</th>
                            <th>Business #</th>
                            <th>Submitted</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in currentList)
                        {
                            var vv = v;
                            <tr style="cursor:pointer" @onclick="() => OpenDetail(vv)">
                                <td><strong>@vv.Name</strong></td>
                                <td>
                                    <span class="assoc-pill @(vv.Type == VendorType.Isw ? "client" : "project")">
                                        @(vv.Type == VendorType.Isw ? "ISW" : "SP")
                                    </span>
                                </td>
                                <td>@vv.Contact <span class="muted" style="font-size:11px;display:block">@vv.Email</span></td>
                                <td class="mono">@(vv.BusinessNumber ?? "—")</td>
                                <td>
                                    <div class="fcl-date">@vv.SubmittedAt.ToString("MMM dd, yyyy")</div>
                                    <div class="fcl-time muted">by @(string.IsNullOrEmpty(vv.SubmittedBy) ? "—" : vv.SubmittedBy)</div>
                                </td>
                                <td><span class="fcl-pill @VendorPillClass(vv.Status)"><span class="fcl-pill-dot"></span>@vv.Status</span></td>
                                <td @onclick:stopPropagation="true">
                                    <button class="btn" style="padding:4px 10px;font-size:11px" @onclick="() => OpenDetail(vv)">View</button>
                                    @if (vv.Status == VendorStatus.Pending)
                                    {
                                        <button class="btn primary" style="padding:4px 10px;font-size:11px;background:#1f6f24;border-color:#155f1a" @onclick="() => Approve(vv.Id)">Approve</button>
                                        <button class="btn" style="padding:4px 10px;font-size:11px;color:var(--danger)" @onclick="() => OpenReject(vv)">Reject</button>
                                    }
                                    else if (vv.Status == VendorStatus.Rejected)
                                    {
                                        <button class="btn" style="padding:4px 10px;font-size:11px" @onclick="() => Reactivate(vv.Id)">Re-open</button>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!currentList.Any())
                        {
                            <tr><td colspan="7" class="muted" style="text-align:center;padding:34px">No @_tab vendors right now.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>

<!-- Detail modal -->
@if (_detail != null)
{
    var v = _detail;
    var linkedFcs = Fc.Rows.Where(r => r.Services.Any(s => s.Vendor == v.Name)).ToList();

    <div class="modal-overlay" @onclick="CloseDetail"></div>
    <div class="modal-card" style="width:min(720px,94vw)" @onclick:stopPropagation="true">
        <header class="modal-head">
            <div>
                <div class="modal-eyebrow">Vendor profile</div>
                <h2>@v.Name</h2>
            </div>
            <button class="bd-close" @onclick="CloseDetail" title="Close">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12" /></svg>
            </button>
        </header>
        <div class="modal-body">
            <div class="kv-grid">
                <div class="kv"><span class="k">Status</span><span class="v"><span class="fcl-pill @VendorPillClass(v.Status)"><span class="fcl-pill-dot"></span>@v.Status</span></span></div>
                <div class="kv"><span class="k">Type</span><span class="v">@(v.Type == VendorType.Isw ? "Independent Support Worker" : "Service Provider")</span></div>
                <div class="kv"><span class="k">Contact</span><span class="v">@v.Contact</span></div>
                <div class="kv"><span class="k">Email</span><span class="v">@v.Email</span></div>
                <div class="kv"><span class="k">Phone</span><span class="v">@v.Phone</span></div>
                <div class="kv"><span class="k">Business #</span><span class="v mono">@(v.BusinessNumber ?? "—")</span></div>
                <div class="kv" style="grid-column:1 / -1"><span class="k">Address</span><span class="v">@(string.IsNullOrEmpty(v.Address) ? "—" : v.Address)</span></div>
                <div class="kv"><span class="k">Submitted</span><span class="v mono">@v.SubmittedAt.ToString("MMM dd, yyyy")</span></div>
                <div class="kv"><span class="k">Submitted by</span><span class="v">@(string.IsNullOrEmpty(v.SubmittedBy) ? "—" : v.SubmittedBy)</span></div>
                @if (v.Status == VendorStatus.Approved)
                {
                    <div class="kv"><span class="k">Approved by</span><span class="v">@(v.ApprovedBy ?? "—")</span></div>
                    <div class="kv"><span class="k">Approved at</span><span class="v mono">@(v.ApprovedAt?.ToString("MMM dd, yyyy") ?? "—")</span></div>
                }
                @if (v.Status == VendorStatus.Rejected && !string.IsNullOrEmpty(v.RejectionReason))
                {
                    <div class="kv" style="grid-column:1 / -1">
                        <span class="k">Rejection reason</span>
                        <span class="v" style="color:var(--danger)">@v.RejectionReason</span>
                    </div>
                }
                <div class="kv" style="grid-column:1 / -1">
                    <span class="k">Support types</span>
                    <span class="v">@(v.SupportTypes.Count == 0 ? "—" : string.Join(", ", v.SupportTypes))</span>
                </div>
                <div class="kv" style="grid-column:1 / -1">
                    <span class="k">Active service-line assignments</span>
                    <span class="v">@linkedFcs.Count FC@(linkedFcs.Count == 1 ? "" : "s")</span>
                </div>
            </div>

            <div style="margin-top:18px">
                <div class="db-head" style="padding:10px 0 6px;border:none;background:transparent">
                    <h3 style="font-size:13px;margin:0">Audit history</h3>
                </div>
                <EntityHistory EntityType="Vendor" EntityId="@v.Id" />
            </div>
        </div>
        <footer class="modal-foot">
            <button class="btn ghost" @onclick="CloseDetail">Close</button>
            @if (v.Status == VendorStatus.Pending)
            {
                <button class="btn primary" @onclick="() => { Approve(v.Id); CloseDetail(); }">Approve</button>
                <button class="btn" style="color:var(--danger)" @onclick="() => OpenReject(v)">Reject</button>
            }
            else if (v.Status == VendorStatus.Rejected)
            {
                <button class="btn" @onclick="() => { Reactivate(v.Id); CloseDetail(); }">Re-open</button>
            }
        </footer>
    </div>
}

<!-- Rejection reason modal -->
@if (_rejecting != null)
{
    <div class="modal-overlay" @onclick="() => _rejecting = null"></div>
    <div class="modal-card" style="width:min(480px,94vw)" @onclick:stopPropagation="true">
        <header class="modal-head">
            <div>
                <div class="modal-eyebrow">Reject vendor</div>
                <h2>@_rejecting.Name</h2>
            </div>
        </header>
        <div class="modal-body">
            <div class="modal-row">
                <label class="modal-lbl">Rejection reason <span class="req">*</span></label>
                <textarea class="modal-input wiz-textarea" placeholder="Explain why this vendor profile is rejected…" @bind="_rejectionReason"></textarea>
            </div>
        </div>
        <footer class="modal-foot">
            <button class="btn ghost" @onclick="() => _rejecting = null">Cancel</button>
            <button class="btn primary" style="background:#b53028;border-color:#8b1f1a" @onclick="ConfirmReject" disabled="@string.IsNullOrWhiteSpace(_rejectionReason)">Confirm reject</button>
        </footer>
    </div>
}

<!-- New vendor modal -->
@if (_newOpen)
{
    <div class="modal-overlay" @onclick="() => _newOpen = false"></div>
    <div class="modal-card" style="width:min(560px,94vw)" @onclick:stopPropagation="true">
        <header class="modal-head">
            <div>
                <div class="modal-eyebrow">Register vendor</div>
                <h2>Submit a new vendor for approval</h2>
            </div>
            <button class="bd-close" @onclick="() => _newOpen = false">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12" /></svg>
            </button>
        </header>
        <div class="modal-body">
            <div class="modal-grid-2">
                <div class="modal-row">
                    <label class="modal-lbl">Vendor name <span class="req">*</span></label>
                    <input class="modal-input" @bind="_nvName" />
                </div>
                <div class="modal-row">
                    <label class="modal-lbl">Type <span class="req">*</span></label>
                    <select class="modal-input" @bind="_nvType">
                        <option value="Isw">Independent Support Worker (ISW)</option>
                        <option value="Sp">Service Provider (SP)</option>
                    </select>
                </div>
                <div class="modal-row">
                    <label class="modal-lbl">Primary contact</label>
                    <input class="modal-input" @bind="_nvContact" />
                </div>
                <div class="modal-row">
                    <label class="modal-lbl">Email</label>
                    <input class="modal-input" @bind="_nvEmail" />
                </div>
                <div class="modal-row">
                    <label class="modal-lbl">Business number</label>
                    <input class="modal-input" @bind="_nvBn" />
                </div>
                <div class="modal-row" style="grid-column:span 2">
                    <label class="modal-lbl">Address</label>
                    <input class="modal-input" @bind="_nvAddress" />
                </div>
            </div>
        </div>
        <footer class="modal-foot">
            <button class="btn ghost" @onclick="() => _newOpen = false">Cancel</button>
            <button class="btn primary" @onclick="CreateNew" disabled="@string.IsNullOrWhiteSpace(_nvName)">Submit for approval</button>
        </footer>
    </div>
}

@code {
    private string _tab = "pending";
    private Vendor? _detail;
    private Vendor? _rejecting;
    private string _rejectionReason = "";

    private bool _newOpen;
    private string _nvName = "";
    private string _nvType = "Isw";
    private string _nvContact = "";
    private string _nvEmail = "";
    private string _nvBn = "";
    private string _nvAddress = "";

    protected override void OnInitialized()
    {
        Vendors.OnChange += R;
        Fc.OnChange += R;
        L.OnChange += R;
        UserCtx.OnChange += R;
    }

    private void R() => InvokeAsync(StateHasChanged);

    private void OpenDetail(Vendor v) { _detail = v; StateHasChanged(); }
    private void CloseDetail() { _detail = null; StateHasChanged(); }

    private void OpenReject(Vendor v) { _rejecting = v; _rejectionReason = ""; _detail = null; StateHasChanged(); }

    private void ConfirmReject()
    {
        if (_rejecting == null || string.IsNullOrWhiteSpace(_rejectionReason)) return;
        Vendors.Reject(_rejecting.Id, _rejectionReason);
        Toasts.Show(ToastKind.Warning, $"{_rejecting.Name} rejected.");
        _rejecting = null;
        _rejectionReason = "";
    }

    private void Approve(string id)
    {
        Vendors.Approve(id);
        Toasts.Show(ToastKind.Success, "Vendor approved.");
    }

    private void Reactivate(string id)
    {
        Vendors.Reactivate(id);
        Toasts.Show(ToastKind.Success, "Vendor reopened for review.");
    }

    private void OpenNewVendor()
    {
        _newOpen = true;
        _nvName = ""; _nvType = "Isw"; _nvContact = ""; _nvEmail = ""; _nvBn = ""; _nvAddress = "";
    }

    private void CreateNew()
    {
        if (string.IsNullOrWhiteSpace(_nvName)) return;
        var type = _nvType == "Sp" ? VendorType.Sp : VendorType.Isw;
        var v = Vendors.Create(_nvName.Trim(), type, _nvContact.Trim(), _nvEmail.Trim(),
                               string.IsNullOrWhiteSpace(_nvBn) ? null : _nvBn.Trim(),
                               string.IsNullOrWhiteSpace(_nvAddress) ? null : _nvAddress.Trim());
        Toasts.Show(ToastKind.Success, $"Submitted {v.Name} for approval.");
        _newOpen = false;
        _tab = "pending";
    }

    private static string VendorPillClass(VendorStatus s) => s switch
    {
        VendorStatus.Approved => "fcl-approved",
        VendorStatus.Pending => "fcl-pending",
        VendorStatus.Rejected => "fcl-rejected",
        _ => "fcl-draft"
    };

    public void Dispose()
    {
        Vendors.OnChange -= R;
        Fc.OnChange -= R;
        L.OnChange -= R;
        UserCtx.OnChange -= R;
    }
}
